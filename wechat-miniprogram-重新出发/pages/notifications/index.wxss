.notifications-page {
  overflow-x: hidden;
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #FFF9F3 0%, #F6F1E8 100%);
}

.notice-nav {
  position: relative;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
  padding-right: 220rpx;
  padding-left: 32rpx;
  background: rgba(255, 249, 243, 0.96);
}

.notice-nav-left {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 247, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(91, 95, 151, 0.1);
}

.notice-nav-left:active {
  opacity: 0.74;
}

.notice-back {
  display: block;
  margin-top: -6rpx;
  font-size: 62rpx;
  font-weight: 600;
  line-height: 1;
  color: #5B5F97;
}

.notice-nav-title {
  position: absolute;
  left: 50%;
  bottom: 24rpx;
  overflow: hidden;
  width: 280rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
  color: #2E2E2A;
  transform: translateX(-50%);
}

.notice-tabs {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
  padding: 24rpx 32rpx 22rpx;
  border-bottom: 1rpx solid rgba(232, 220, 203, 0.78);
  background: rgba(255, 249, 243, 0.9);
}

.notice-tab {
  position: relative;
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 70rpx;
  border-radius: 999rpx;
  color: rgba(123, 116, 107, 0.72);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.notice-tab.active {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
  box-shadow: 0 10rpx 24rpx rgba(91, 95, 151, 0.1);
}

.filter-dot {
  position: absolute;
  top: 10rpx;
  right: 18rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #E7A0B3;
  box-shadow: 0 0 0 4rpx rgba(255, 252, 247, 0.9);
}

.notice-state {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: auto;
  min-height: 124rpx;
  margin: 28rpx 32rpx 0;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(232, 220, 203, 0.95);
  border-radius: 28rpx;
  color: #7B746B;
  background:
    linear-gradient(135deg, rgba(255, 252, 247, 0.98), rgba(246, 241, 232, 0.86)),
    #FFFCF7;
  box-shadow: 0 20rpx 44rpx rgba(91, 95, 151, 0.1);
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
}

.notification-list {
  display: grid;
  box-sizing: border-box;
  width: 100%;
  padding: 0 32rpx;
  background: transparent;
}

.notification-item {
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr) 88rpx;
  column-gap: 24rpx;
  align-items: flex-start;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  padding: 34rpx 0 32rpx;
  border-bottom: 1rpx solid rgba(232, 220, 203, 0.74);
}

.notification-item:active {
  opacity: 0.72;
}

.avatar-wrap,
.avatar-img,
.avatar-fallback {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
}

.avatar-wrap {
  overflow: hidden;
}

.avatar-img {
  display: block;
  background: rgba(175, 166, 219, 0.16);
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5B5F97;
  background:
    linear-gradient(135deg, rgba(175, 166, 219, 0.24), rgba(231, 160, 179, 0.14)),
    #FFFCF7;
  font-size: 32rpx;
  font-weight: 800;
}

.notification-main {
  min-width: 0;
}

.notification-line {
  overflow-wrap: anywhere;
  word-break: break-word;
  font-size: 32rpx;
  line-height: 1.34;
  color: #2E2E2A;
}

.actor-name {
  font-weight: 900;
}

.action-label {
  font-weight: 500;
}

.unread-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  vertical-align: middle;
  background: #E7A0B3;
}

.notification-time {
  margin-top: 12rpx;
  color: rgba(123, 116, 107, 0.64);
  font-size: 28rpx;
  line-height: 1.1;
}

.notification-preview {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 18rpx;
  color: #2E2E2A;
  font-size: 30rpx;
  line-height: 1.42;
  word-break: break-word;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.target-thumb {
  display: block;
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  background: rgba(214, 171, 79, 0.14);
}

.target-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #D6AB4F;
  font-size: 30rpx;
  font-weight: 800;
  background:
    linear-gradient(135deg, rgba(214, 171, 79, 0.16), rgba(242, 164, 92, 0.1)),
    #FFFCF7;
}

@media (max-width: 340px) {
  .notice-tabs {
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .notice-tab {
    font-size: 27rpx;
  }

  .notification-list {
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .notification-item {
    grid-template-columns: 82rpx minmax(0, 1fr) 76rpx;
    column-gap: 18rpx;
  }

  .avatar-wrap,
  .avatar-img,
  .avatar-fallback,
  .target-thumb {
    width: 76rpx;
    height: 76rpx;
  }

  .notification-line {
    font-size: 30rpx;
  }
}
