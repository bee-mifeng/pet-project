.form-card {
  margin-top: 30rpx;
  padding: 30rpx;
}

.field {
  margin-bottom: 30rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.picker-text {
  color: rgba(31, 45, 42, 0.74);
}

.field-help {
  margin: -4rpx 0 14rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: rgba(31, 45, 42, 0.56);
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(47, 75, 56, 0.08);
}

.segment {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 72rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.2;
  color: rgba(31, 45, 42, 0.64);
}

.segment.active {
  color: #fffdf8;
  background: #2f4b38;
}

.photo-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  border: 1rpx dashed rgba(47, 75, 56, 0.26);
  border-radius: 28rpx;
  background: #fffaf1;
}

.video-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 260rpx;
  border: 1rpx dashed rgba(47, 75, 56, 0.26);
  border-radius: 28rpx;
  background: #fffaf1;
  font-size: 28rpx;
  color: #2f4b38;
}

.video-box {
  overflow: hidden;
  border: 1rpx solid rgba(47, 75, 56, 0.1);
  border-radius: 28rpx;
  background: #fffaf1;
}

.video-preview {
  display: block;
  width: 100%;
  height: 360rpx;
}

.remove-video {
  margin: 18rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-empty {
  font-size: 28rpx;
  color: #2f4b38;
}

.short-textarea {
  min-height: 140rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(47, 75, 56, 0.08);
}

.switch-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #2f4b38;
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: rgba(31, 45, 42, 0.58);
}

.submit-button {
  margin-top: 28rpx;
}
