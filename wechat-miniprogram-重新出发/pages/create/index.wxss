.form-card {
  margin-top: 30rpx;
  padding: 30rpx;
}

.field {
  margin-bottom: 30rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.picker-text {
  color: rgba(46, 46, 42, 0.74);
}

.field-help {
  margin: -4rpx 0 14rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: rgba(46, 46, 42, 0.56);
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(175, 166, 219, 0.14);
}

.segment {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 72rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.2;
  color: rgba(46, 46, 42, 0.64);
}

.segment.active {
  color: #FFFCF7;
  box-shadow: 0 12rpx 24rpx rgba(91, 95, 151, 0.14);
}

.segment-living.active {
  background: #5B5F97;
}

.segment-star.active {
  background: linear-gradient(135deg, #E7A0B3 0%, #D6AB4F 100%);
}

.photo-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  border: 1rpx dashed #AFA6DB;
  border-radius: 28rpx;
  background: #FBF8F1;
}

.video-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 260rpx;
  border: 1rpx dashed #E7A0B3;
  border-radius: 28rpx;
  background: #FBF8F1;
  font-size: 28rpx;
  color: #E7A0B3;
}

.video-box {
  overflow: hidden;
  border: 1rpx solid rgba(91, 95, 151, 0.1);
  border-radius: 28rpx;
  background: #FBF8F1;
}

.video-preview {
  display: block;
  width: 100%;
  height: 360rpx;
}

.remove-video {
  margin: 18rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-empty {
  font-size: 28rpx;
  color: #5B5F97;
}

.short-textarea {
  min-height: 140rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(91, 95, 151, 0.08);
}

.public-switch-row {
  margin: 8rpx -6rpx 0;
  padding: 24rpx 18rpx;
  border-top: 0;
  border-radius: 24rpx;
  background: rgba(214, 171, 79, 0.12);
}

.switch-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #5B5F97;
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.submit-button {
  margin-top: 28rpx;
}
