.filter-panel {
  display: grid;
  gap: 18rpx;
  margin: 28rpx 0 24rpx;
}

.filter-group {
  display: grid;
  gap: 12rpx;
}

.filter-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5F97;
}

.filters {
  width: 100%;
}

.filter-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 auto;
  min-height: 64rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  line-height: 1.2;
  color: #7B746B;
  background: #FFFCF7;
  border: 1rpx solid #E8DCCB;
}

.filter.active {
  color: #FFFCF7;
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 100%);
  border-color: transparent;
}

.card-list {
  display: grid;
  gap: 22rpx;
}

.memory-card {
  overflow: hidden;
  box-shadow: 0 18rpx 44rpx rgba(91, 95, 151, 0.08);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  background: #FBF8F1;
}

.card-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.video-badge {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFCF7;
  background: linear-gradient(135deg, rgba(91, 95, 151, 0.86), rgba(231, 160, 179, 0.86));
}

.card-body {
  padding: 28rpx;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #5B5F97;
}

.status-badge.status-living {
  color: #B7657C;
  background: #FBEAF0;
}

.status-badge.status-star {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.16);
}

.pet-type-chip {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pet-type-cat {
  color: #B7657C;
  background: #FBEAF0;
}

.pet-type-dog {
  color: #B56B24;
  background: #FFF0DF;
}

.pet-type-smallPet {
  color: #5F7A43;
  background: rgba(138, 166, 99, 0.16);
}

.pet-type-exoticPet {
  color: #3E7B83;
  background: rgba(94, 167, 176, 0.16);
}

.pet-type-other {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.card-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.6);
}

.card-story {
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(46, 46, 42, 0.74);
}

.story-name {
  margin-right: 12rpx;
  font-weight: 700;
  color: #2E2E2A;
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 4rpx 2rpx;
}

.feed-action,
.feed-stat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 54rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
}

.feed-action {
  width: auto;
  margin: 0;
  flex: 0 0 auto;
}

.action-icon {
  margin-right: 8rpx;
  line-height: 1;
}

.like-action {
  display: inline-flex;
  align-self: flex-start;
  min-width: 94rpx;
  max-width: 180rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(231, 160, 179, 0.28);
  border-radius: 999rpx;
  color: #5B5F97;
  background: rgba(255, 252, 247, 0.66);
  box-shadow: 0 10rpx 24rpx rgba(183, 101, 124, 0.08);
}

.like-action.liked {
  border-color: rgba(183, 101, 124, 0.28);
  color: #B7657C;
  background: rgba(251, 234, 240, 0.7);
}

.paw-action {
  margin-left: auto;
  color: #D6AB4F;
}

.paw-action .action-icon {
  font-size: 24rpx;
}
