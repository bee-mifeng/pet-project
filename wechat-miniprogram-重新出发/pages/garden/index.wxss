.filter-panel {
  display: grid;
  gap: 18rpx;
  margin: 28rpx 0 24rpx;
}

.filter-group {
  display: grid;
  gap: 12rpx;
}

.filter-title {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(47, 75, 56, 0.8);
}

.filters {
  width: 100%;
  white-space: nowrap;
}

.filter-wrap {
  display: flex;
  gap: 14rpx;
}

.filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 auto;
  min-height: 64rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  line-height: 1.2;
  color: #2f4b38;
  background: rgba(47, 75, 56, 0.09);
}

.filter.active {
  color: #fffdf8;
  background: #2f4b38;
}

.card-list {
  display: grid;
  gap: 22rpx;
}

.memory-card {
  overflow: hidden;
}

.card-cover {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  background: #fffaf1;
}

.card-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.video-badge {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fffdf8;
  background: rgba(47, 75, 56, 0.82);
}

.card-body {
  padding: 28rpx;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f4b38;
}

.card-meta,
.card-stats {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(31, 45, 42, 0.6);
}

.card-story {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(31, 45, 42, 0.74);
}

.card-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.card-button {
  margin-top: 22rpx;
}
