.filter-panel {
  display: grid;
  gap: 18rpx;
  margin: 28rpx 0 24rpx;
}

.filter-group {
  display: grid;
  gap: 12rpx;
}

.filter-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5F97;
}

.filters {
  width: 100%;
  white-space: nowrap;
}

.filter-wrap {
  display: flex;
  gap: 14rpx;
}

.filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 auto;
  min-height: 64rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  line-height: 1.2;
  color: #7B746B;
  background: #FFFCF7;
  border: 1rpx solid #E8DCCB;
}

.filter.active {
  color: #FFFCF7;
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 100%);
  border-color: transparent;
}

.card-list {
  display: grid;
  gap: 22rpx;
}

.memory-card {
  overflow: hidden;
  box-shadow: 0 18rpx 44rpx rgba(91, 95, 151, 0.08);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  background: #FBF8F1;
}

.card-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.video-badge {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFCF7;
  background: linear-gradient(135deg, rgba(91, 95, 151, 0.86), rgba(231, 160, 179, 0.86));
}

.card-body {
  padding: 28rpx;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #5B5F97;
}

.status-badge.status-living {
  color: #B7657C;
  background: #FBEAF0;
}

.status-badge.status-star {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.16);
}

.pet-type-chip {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pet-type-cat {
  color: #B7657C;
  background: #FBEAF0;
}

.pet-type-dog {
  color: #B56B24;
  background: #FFF0DF;
}

.pet-type-other {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.card-meta,
.card-stats {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.6);
}

.card-story {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(46, 46, 42, 0.74);
}

.card-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.card-button {
  margin-top: 22rpx;
}

.card-stats text:nth-child(1) {
  color: #5B5F97;
}

.card-stats text:nth-child(2) {
  color: #D6AB4F;
}
