<view class="page garden-page safe-bottom">
  <view class="page-title">记忆花园</view>
  <view class="page-desc">这里收藏着主人愿意分享的毛孩子故事。每一段陪伴，都值得被温柔记住。</view>

  <view class="filter-panel">
    <view class="filter-group">
      <view class="filter-title">宠物</view>
      <view class="filters">
        <view class="filter-wrap">
          <view
            wx:for="{{petTypeFilters}}"
            wx:key="value"
            class="filter {{activePetType === item.value ? 'active' : ''}}"
            data-filter="{{item.value}}"
            bindtap="changePetTypeFilter"
          >{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-title">状态</view>
      <view class="filters">
        <view class="filter-wrap">
          <view
            wx:for="{{statusFilters}}"
            wx:key="value"
            class="filter {{activePetStatus === item.value ? 'active' : ''}}"
            data-filter="{{item.value}}"
            bindtap="changeStatusFilter"
          >{{item.label}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty card">正在整理记忆花园...</view>
  <view wx:elif="{{loadFailed}}" class="empty card">暂时没有加载成功，请稍后再试。</view>
  <view wx:elif="{{cards.length === 0}}" class="empty card">这里还很安静，等待更多主人分享毛孩子的故事。</view>
  <view wx:else class="card-list">
    <view wx:for="{{cards}}" wx:key="_id" class="memory-card card" data-id="{{item._id}}" bindtap="openCard">
      <view class="card-cover">
        <image class="card-photo" src="{{item.photo_src}}" mode="aspectFill"></image>
        <view wx:if="{{item.video_src}}" class="video-badge">含视频</view>
      </view>
      <view class="card-body">
        <view class="card-top">
          <view class="card-name">{{item.pet_name}}</view>
          <view class="badge status-badge status-{{item.pet_status}}">{{item.pet_status_label}}</view>
        </view>
        <view class="card-meta">
          <text class="pet-type-chip pet-type-{{item.pet_type}}">{{item.pet_type_label}}</text>
          <text> · {{item.timeline}}</text>
        </view>
        <view class="card-story">
          <text class="story-name">{{item.pet_name}}</text>
          <text>{{item.brief_story}}</text>
        </view>
        <view class="card-actions">
          <view class="feed-action like-action {{item.has_liked ? 'liked' : ''}}" data-id="{{item._id}}" data-type="like" catchtap="interact">
            <text class="action-icon">{{item.has_liked ? "♥" : "♡"}}</text>
            <text>{{item.like_count || 0}}</text>
          </view>
          <view class="feed-stat paw-action">
            <text class="action-icon">爪印</text>
            <text>{{item.paw_lights_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
