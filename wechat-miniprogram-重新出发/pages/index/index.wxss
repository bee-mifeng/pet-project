.hero {
  padding: 18rpx 0 12rpx;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 34rpx;
}

.trust {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  min-height: 72rpx;
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #2f4b38;
  background: rgba(122, 136, 118, 0.16);
}

.feature-list {
  display: grid;
  gap: 18rpx;
}

.feature-card,
.note-card {
  padding: 28rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f4b38;
}

.feature-desc,
.note-card {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(31, 45, 42, 0.7);
}

.sample-card {
  overflow: hidden;
}

.sample-photo {
  display: block;
  width: 100%;
  height: 360rpx;
}

.sample-body {
  padding: 28rpx;
}

.sample-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.sample-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f4b38;
}

.sample-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(31, 45, 42, 0.62);
}

.sample-story {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: rgba(31, 45, 42, 0.74);
}

.policy-links {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
  color: #9b6f2f;
}
