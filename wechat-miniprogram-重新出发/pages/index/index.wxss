.hero {
  padding: 18rpx 0 12rpx;
}

.hero .page-title {
  color: #5B5F97;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 34rpx;
}

.hero-actions .primary-button {
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 55%, #F2A45C 100%);
  box-shadow: 0 18rpx 34rpx rgba(91, 95, 151, 0.18);
}

.hero-actions .ghost-button {
  color: #5B5F97;
  background: #FFFCF7;
  border-color: #AFA6DB;
}

.trust {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  min-height: 72rpx;
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #7B746B;
  background: linear-gradient(135deg, rgba(175, 166, 219, 0.16), rgba(231, 160, 179, 0.14), rgba(242, 164, 92, 0.12));
}

.feature-list {
  display: grid;
  gap: 18rpx;
}

.feature-card,
.note-card {
  padding: 28rpx;
  border-top: 6rpx solid #E7A0B3;
}

.feature-card:nth-child(3n + 1) {
  border-top-color: #AFA6DB;
}

.feature-card:nth-child(3n + 2) {
  border-top-color: #E7A0B3;
}

.feature-card:nth-child(3n) {
  border-top-color: #F2A45C;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5B5F97;
}

.feature-desc,
.note-card {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(46, 46, 42, 0.7);
}

.sample-card {
  overflow: hidden;
}

.sample-photo {
  display: block;
  width: 100%;
  height: 360rpx;
}

.sample-body {
  padding: 28rpx;
}

.sample-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.sample-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #5B5F97;
}

.sample-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.sample-story {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: rgba(46, 46, 42, 0.74);
}

.policy-links {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
  color: #D6AB4F;
}
