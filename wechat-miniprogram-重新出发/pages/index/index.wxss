.hero {
  padding: 18rpx 0 12rpx;
}

.hero .page-title {
  color: #5B5F97;
}

.logo {
  width: 188rpx;
  height: 188rpx;
  margin-bottom: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 34rpx;
}

.hero-actions .primary-button {
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 55%, #F2A45C 100%);
  box-shadow: 0 18rpx 34rpx rgba(91, 95, 151, 0.18);
}

.trust {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  min-height: 72rpx;
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #7B746B;
  background: linear-gradient(135deg, rgba(175, 166, 219, 0.16), rgba(231, 160, 179, 0.14), rgba(242, 164, 92, 0.12));
}

.feature-list {
  display: grid;
  gap: 18rpx;
}

.feature-card,
.note-card {
  padding: 28rpx;
  border-top: 6rpx solid #E7A0B3;
}

.feature-card:nth-child(3n + 1) {
  border-top-color: #AFA6DB;
}

.feature-card:nth-child(3n + 2) {
  border-top-color: #E7A0B3;
}

.feature-card:nth-child(3n) {
  border-top-color: #F2A45C;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5B5F97;
}

.feature-desc,
.note-card {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(46, 46, 42, 0.7);
}

.sample-card {
  overflow: hidden;
  box-shadow: 0 18rpx 44rpx rgba(91, 95, 151, 0.08);
}

.sample-photo {
  display: block;
  width: 100%;
  height: 350rpx;
  background: #FBF8F1;
}

.sample-body {
  padding: 28rpx;
}

.sample-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.sample-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #5B5F97;
}

.status-badge.status-living {
  color: #B7657C;
  background: #FBEAF0;
}

.pet-type-chip {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pet-type-cat {
  color: #B7657C;
  background: #FBEAF0;
}

.pet-type-dog {
  color: #B56B24;
  background: #FFF0DF;
}

.pet-type-smallPet {
  color: #5F7A43;
  background: rgba(138, 166, 99, 0.16);
}

.pet-type-exoticPet {
  color: #3E7B83;
  background: rgba(94, 167, 176, 0.16);
}

.pet-type-other {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.sample-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.6);
}

.sample-story {
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(46, 46, 42, 0.74);
}

.sample-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 4rpx 2rpx;
}

.sample-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 54rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
}

.sample-action-icon {
  margin-right: 8rpx;
  line-height: 1;
}

.sample-like {
  min-width: 94rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(231, 160, 179, 0.28);
  border-radius: 999rpx;
  color: #5B5F97;
  background: rgba(255, 252, 247, 0.66);
  box-shadow: 0 10rpx 24rpx rgba(183, 101, 124, 0.08);
}

.sample-like .sample-action-icon {
  font-size: 34rpx;
}

.sample-paw {
  margin-left: auto;
  color: #D6AB4F;
}

.sample-paw .sample-action-icon {
  font-size: 24rpx;
}

.policy-links {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
  color: #D6AB4F;
}
