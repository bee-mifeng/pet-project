.form-card {
  margin-top: 30rpx;
  padding: 30rpx;
}

.field {
  margin-bottom: 30rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.picker-text {
  color: rgba(46, 46, 42, 0.74);
}

.field-help {
  margin: -4rpx 0 14rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: rgba(46, 46, 42, 0.56);
}

.media-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  width: 100%;
}

.media-button {
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  height: 78rpx;
  padding: 0 12rpx;
  margin: 0;
  font-size: 26rpx;
  line-height: 1.2;
}

.media-button:first-child {
  color: #5B5F97;
  border-color: #AFA6DB;
}

.media-button:last-child {
  color: #F2A45C;
  border-color: #E7A0B3;
}

.media-box {
  overflow: hidden;
  border: 1rpx solid rgba(175, 166, 219, 0.26);
  border-radius: 28rpx;
  background: #FBF8F1;
}

.photo-preview,
.video-preview {
  display: block;
  width: 100%;
  height: 360rpx;
}

.remove-media {
  margin: 18rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 0 0;
  border-top: 1rpx solid rgba(91, 95, 151, 0.08);
}

.public-switch-row {
  margin: 8rpx -6rpx 0;
  padding: 24rpx 18rpx;
  border-top: 0;
  border-radius: 24rpx;
  background: rgba(214, 171, 79, 0.12);
}

.switch-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #5B5F97;
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.submit-button {
  margin-top: 28rpx;
}
