<view class="page card-page safe-bottom">
  <view class="page-title">记忆卡</view>

  <view wx:if="{{loading}}" class="empty card">正在打开这页记忆...</view>
  <view wx:elif="{{loadFailed}}" class="empty card">暂时没有加载成功，请稍后再试。</view>
  <view wx:elif="{{!card}}" class="empty card">没有找到这张记忆卡。</view>
  <block wx:else>
    <view class="detail card">
      <image wx:if="{{card.photo_src}}" class="hero-photo" src="{{card.photo_src}}" mode="aspectFill"></image>
      <view wx:if="{{card.video_src}}" class="video-section">
        <view class="media-title">视频记忆</view>
        <video class="hero-video" src="{{card.video_src}}" poster="{{card.photo_src}}" controls object-fit="contain"></video>
      </view>
      <view class="detail-body">
        <view class="detail-top">
          <view>
            <view class="pet-name">{{card.pet_name}}</view>
            <view class="pet-meta">{{card.pet_type_label}} · {{card.timeline}}</view>
          </view>
          <view class="badge detail-status status-{{card.pet_status_class}}">{{card.pet_status_label}}</view>
        </view>

        <view class="story-block">
          <view class="block-title">关于它的一段记忆</view>
          <view class="block-text">{{card.story || "主人还没有写下故事。"}}</view>
        </view>

        <view class="story-block">
          <view class="block-title">最想对它说的话</view>
          <view class="quote">{{card.message || "这句话先安静地留在心里。"}}</view>
        </view>

        <view class="interaction-row">
          <button
            class="ghost-button small-button interaction-like {{card.has_liked ? 'active' : ''}}"
            data-type="{{card.primary_interaction_type}}"
            loading="{{interacting}}"
            bindtap="interact"
          >
            <text class="like-heart">{{card.has_liked ? "♥" : "♡"}}</text>
            <text>{{card.has_liked ? "已喜欢" : "喜欢"}} {{card.primary_interaction_count}}</text>
          </button>
          <view class="view-stat">爪印 {{card.paw_lights_count || 0}}</view>
        </view>

        <view wx:if="{{isOwner}}" class="owner-panel">
          <view class="owner-status-section">
            <view class="owner-label-row">
              <view class="owner-label">毛孩子状态</view>
              <view class="owner-hint">主人可修改</view>
            </view>
            <view class="owner-segmented">
              <view
                class="owner-segment owner-segment-living {{card.pet_status === 'living' ? 'active' : ''}}"
                data-status="living"
                bindtap="changeOwnerPetStatus"
              >陪伴中</view>
              <picker class="owner-segment-picker" mode="date" value="{{card.star_date}}" bindchange="changeOwnerStarDate">
                <view class="owner-segment owner-segment-star {{card.pet_status === 'star' ? 'active' : ''}}">在星星上</view>
              </picker>
            </view>
            <picker wx:if="{{card.pet_status === 'star'}}" mode="date" value="{{card.star_date}}" bindchange="changeOwnerStarDate">
              <view class="owner-date-row">
                <text>去星星上的日子</text>
                <text>{{card.star_date || "选择日期"}}</text>
              </view>
            </picker>
          </view>
          <view class="owner-status">公开状态：{{card.visibility_label}}</view>
          <button wx:if="{{card.visibility === 'private' || card.visibility === 'rejected'}}" class="quiet-button owner-button" bindtap="applyPublic">申请进入记忆花园</button>
          <button wx:if="{{card.visibility === 'public'}}" class="danger-button owner-button" bindtap="makePrivate">取消公开展示</button>
          <button wx:if="{{card.visibility === 'pending'}}" class="quiet-button owner-button" bindtap="makePrivate">撤回公开申请</button>
        </view>
      </view>
    </view>

    <view class="section-title memory-section-title">它的小爪记忆</view>
    <view class="memory-actions">
      <button wx:if="{{isOwner}}" class="primary-button memory-add-button" bindtap="goCreateMemoryItem">添加小爪记忆</button>
    </view>
    <view wx:if="{{memoryItems.length === 0}}" class="empty card">还没有小爪记忆。可以慢慢补上它陪伴你的每一个小瞬间。</view>
    <view wx:else class="memory-items">
      <view wx:for="{{memoryItems}}" wx:key="_id" class="memory-item card" data-id="{{item._id}}" bindtap="openMemoryItem">
        <view class="memory-item-top">
          <view>
            <view class="memory-date">{{item.memory_date_label}}</view>
            <view class="memory-title">{{item.title}}</view>
          </view>
          <view wx:if="{{isOwner}}" class="badge memory-status memory-status-{{item.visibility}}">{{item.visibility_label}}</view>
        </view>
        <image wx:if="{{item.item_type === 'photo' && item.media_src}}" class="memory-media" src="{{item.media_src}}" mode="aspectFill"></image>
        <video wx:elif="{{item.item_type === 'video' && item.media_src}}" class="memory-media" src="{{item.media_src}}" poster="{{item.cover_src}}" controls object-fit="contain" catchtap="noop"></video>
        <view wx:if="{{item.content}}" class="memory-content">{{item.content}}</view>
        <view class="memory-item-actions">
          <view class="memory-item-action">
            <text class="memory-action-icon heart-icon">♥</text>
            <text class="memory-action-count">{{item.likes_count || 0}}</text>
          </view>
          <view class="memory-item-action">
            <text class="memory-action-icon comment-icon"></text>
            <text class="memory-action-count">{{item.comments_count || 0}}</text>
          </view>
          <view class="memory-item-action">
            <text class="memory-paw-emoji">🐾</text>
            <text class="memory-action-count">{{item.paw_lights_count || 0}}</text>
            <text class="memory-save-label">爪印</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
