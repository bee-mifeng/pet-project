.detail {
  margin-top: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 52rpx rgba(175, 166, 219, 0.16);
}

.hero-photo,
.hero-video {
  display: block;
  width: 100%;
  height: 520rpx;
}

.video-section {
  padding: 24rpx 30rpx 0;
  background: #FFFCF7;
}

.media-title {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #5B5F97;
}

.video-section .hero-video {
  overflow: hidden;
  border-radius: 24rpx;
  background: #111;
}

.detail-body {
  padding: 30rpx;
}

.detail-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.pet-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #5B5F97;
}

.pet-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.story-block {
  margin-top: 30rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #5B5F97;
}

.block-text {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(46, 46, 42, 0.76);
}

.quote {
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #B7657C;
  background: linear-gradient(135deg, rgba(231, 160, 179, 0.12), rgba(214, 171, 79, 0.12));
}

.interaction-row {
  position: relative;
  display: block;
  margin-top: 30rpx;
}

.small-button {
  height: 92rpx;
  line-height: 1.2;
}

.interaction-like {
  width: 100%;
  margin: 0;
  border: 1rpx solid rgba(231, 160, 179, 0.28);
  color: #B7657C;
  background: rgba(255, 252, 247, 0.66);
  box-shadow: 0 12rpx 28rpx rgba(183, 101, 124, 0.08);
  transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}

.interaction-like.active {
  color: #FFFCF7;
  border-color: transparent;
  background: linear-gradient(135deg, #B7657C 0%, #E7A0B3 62%, #F2A45C 100%);
  box-shadow: 0 18rpx 36rpx rgba(183, 101, 124, 0.22);
}

.like-heart {
  margin-right: 10rpx;
  font-size: 32rpx;
  line-height: 1;
}

.view-stat {
  position: absolute;
  right: 26rpx;
  bottom: 14rpx;
  box-sizing: border-box;
  min-height: 0;
  padding: 0;
  border-radius: 0;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  color: rgba(181, 107, 36, 0.82);
  background: transparent;
}

.owner-panel {
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(214, 171, 79, 0.12);
}

.owner-status-section {
  display: grid;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.owner-label-row,
.owner-date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.owner-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #5B5F97;
}

.owner-hint {
  font-size: 22rpx;
  color: rgba(46, 46, 42, 0.5);
}

.owner-segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.76);
}

.owner-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: rgba(46, 46, 42, 0.64);
}

.owner-segment-picker {
  min-width: 0;
}

.owner-segment.active {
  color: #FFFCF7;
}

.owner-segment-living.active {
  background: #5B5F97;
}

.owner-segment-star.active {
  background: linear-gradient(135deg, #E7A0B3 0%, #D6AB4F 100%);
}

.owner-date-row {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #5B5F97;
  background: rgba(255, 252, 247, 0.86);
}

.owner-status {
  font-size: 25rpx;
  color: #7B746B;
}

.owner-button {
  margin-top: 16rpx;
}

.memory-section-title {
  margin-bottom: 14rpx;
}

.memory-actions {
  margin-bottom: 18rpx;
}

.memory-add-button {
  width: 100%;
  margin: 0;
}

.memory-items {
  display: grid;
  gap: 18rpx;
}

.memory-item {
  overflow: hidden;
}

.memory-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx 26rpx 18rpx;
}

.memory-date {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.memory-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #5B5F97;
}

.memory-status-private {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.16);
}

.memory-status-pending {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.memory-status-public {
  color: #5B5F97;
  background: rgba(91, 95, 151, 0.12);
}

.memory-status-rejected {
  color: #9A4A4A;
  background: rgba(180, 90, 90, 0.1);
}

.memory-media {
  display: block;
  width: 100%;
  height: 420rpx;
  background: #111;
}

.memory-content {
  padding: 22rpx 26rpx 28rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: rgba(46, 46, 42, 0.74);
}

.memory-item-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  justify-items: center;
  box-sizing: border-box;
  min-height: 86rpx;
  padding: 12rpx 20rpx 24rpx;
  border-top: 1rpx solid rgba(232, 220, 203, 0.58);
}

.memory-item-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  max-width: 154rpx;
  height: 58rpx;
  gap: 8rpx;
  line-height: 1;
  color: #111820;
}

.memory-action-icon {
  position: relative;
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 40rpx;
  height: 40rpx;
  color: #111820;
}

.heart-icon {
  width: auto;
  min-width: 40rpx;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
  color: #B7657C;
}

.comment-icon {
  width: 40rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% 50% 46% 50%;
  transform: rotate(5deg);
}

.comment-icon::after {
  content: "";
  position: absolute;
  right: 2rpx;
  bottom: -3rpx;
  width: 13rpx;
  height: 13rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(34deg);
  transform-origin: center;
  background: #FFFCF7;
}

.memory-paw-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  font-size: 30rpx;
  line-height: 1;
}

.memory-action-count {
  overflow: hidden;
  max-width: 46rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1;
  color: #111820;
}

.memory-save-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  color: #D6AB4F;
}

.detail-status.status-living {
  color: #B7657C;
  background: #FBEAF0;
}

.detail-status.status-star {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}
