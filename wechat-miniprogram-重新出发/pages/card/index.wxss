.detail {
  margin-top: 24rpx;
  overflow: hidden;
}

.hero-photo,
.hero-video {
  display: block;
  width: 100%;
  height: 520rpx;
}

.video-section {
  padding: 24rpx 30rpx 0;
  background: #fffdf8;
}

.media-title {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #2f4b38;
}

.video-section .hero-video {
  overflow: hidden;
  border-radius: 24rpx;
  background: #111;
}

.detail-body {
  padding: 30rpx;
}

.detail-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.pet-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #2f4b38;
}

.pet-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(31, 45, 42, 0.62);
}

.story-block {
  margin-top: 30rpx;
}

.block-title,
.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f4b38;
}

.block-text {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(31, 45, 42, 0.76);
}

.quote {
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2f4b38;
  background: rgba(218, 172, 67, 0.12);
}

.interaction-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 30rpx;
}

.small-button {
  height: 78rpx;
  line-height: 1.2;
}

.owner-panel {
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(47, 75, 56, 0.07);
}

.owner-status-section {
  display: grid;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.owner-label-row,
.owner-date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.owner-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #2f4b38;
}

.owner-hint {
  font-size: 22rpx;
  color: rgba(31, 45, 42, 0.5);
}

.owner-segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.76);
}

.owner-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: rgba(31, 45, 42, 0.64);
}

.owner-segment.active {
  color: #fffdf8;
  background: #2f4b38;
}

.owner-date-row {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #2f4b38;
  background: rgba(255, 253, 248, 0.86);
}

.owner-status {
  font-size: 25rpx;
  color: #2f4b38;
}

.owner-button {
  margin-top: 16rpx;
}

.message-panel {
  margin-top: 24rpx;
  padding: 30rpx;
}

.message-panel .form-control {
  margin-top: 18rpx;
}

.message-textarea {
  min-height: 150rpx;
}

.message-button {
  margin-top: 18rpx;
}

.messages {
  display: grid;
  gap: 16rpx;
}

.message-item {
  padding: 24rpx;
}

.message-name {
  font-size: 25rpx;
  font-weight: 700;
  color: #2f4b38;
}

.message-content {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(31, 45, 42, 0.74);
}
