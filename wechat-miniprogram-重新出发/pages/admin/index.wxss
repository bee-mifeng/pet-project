.admin-meta {
  margin-top: 28rpx;
  padding: 24rpx;
  font-size: 25rpx;
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.admin-page .page-title,
.admin-page .section-title {
  color: #5B5F97;
}

.admin-openid {
  margin-top: 10rpx;
  word-break: break-all;
  font-size: 22rpx;
  color: rgba(46, 46, 42, 0.62);
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin: 28rpx 0 22rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(175, 166, 219, 0.14);
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 72rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.2;
  color: rgba(46, 46, 42, 0.64);
}

.tab.active {
  color: #FFFCF7;
  background: #5B5F97;
}

.review-list {
  display: grid;
  gap: 18rpx;
}

.review-card,
.memory-item-review {
  overflow: hidden;
}

.review-photo,
.review-video {
  width: 100%;
  height: 320rpx;
  display: block;
}

.review-video-wrap {
  padding: 22rpx 26rpx 0;
  background: #FFFCF7;
}

.review-media-title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #F2A45C;
}

.review-video-wrap .review-video {
  overflow: hidden;
  border-radius: 22rpx;
  background: #111;
}

.review-body,
.message-review {
  padding: 26rpx;
}

.review-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.review-meta,
.message-card-id {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: rgba(46, 46, 42, 0.58);
}

.review-text,
.message-content {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(46, 46, 42, 0.74);
}

.message-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #5B5F97;
}

.review-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  width: 100%;
  height: 76rpx;
  margin: 0;
  font-size: 26rpx;
  line-height: 1.2;
}

.admin-page .primary-button.action-button {
  background: #5B5F97;
  box-shadow: none;
}
