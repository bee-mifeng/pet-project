.admin-entry {
  display: grid;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 26rpx;
  border-color: rgba(214, 171, 79, 0.5);
  background: #FFFCF7;
}

.admin-entry-body {
  min-width: 0;
}

.admin-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.admin-entry-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(46, 46, 42, 0.62);
}

.admin-entry-button {
  width: 100%;
  height: 76rpx;
  margin: 0;
  font-size: 26rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 55%, #F2A45C 100%);
}

.mine-list {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.mine-item {
  display: grid;
  grid-template-columns: 168rpx 1fr;
  gap: 22rpx;
  padding: 20rpx;
}

.mine-photo {
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
}

.mine-body {
  min-width: 0;
  padding: 8rpx 0;
}

.mine-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.mine-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.mine-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.mine-time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.meta-dot {
  color: rgba(46, 46, 42, 0.34);
}

.status-chip {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #B7657C;
  background: rgba(231, 160, 179, 0.14);
}

.status-star {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.visibility-public {
  color: #5B5F97;
  background: rgba(91, 95, 151, 0.12);
}

.visibility-pending {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.visibility-private {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.16);
}

.visibility-rejected {
  color: #9A4A4A;
  background: rgba(154, 74, 74, 0.12);
}

.empty-button {
  margin-top: 24rpx;
}

.mine-create-card {
  margin-top: 28rpx;
  padding: 36rpx 30rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(231, 160, 179, 0.16), transparent 210rpx),
    linear-gradient(135deg, rgba(175, 166, 219, 0.12), rgba(242, 164, 92, 0.08)),
    #FFFCF7;
}

.mine-create-kicker {
  font-size: 24rpx;
  font-weight: 700;
  color: #B7657C;
}

.mine-create-title {
  margin-top: 14rpx;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #5B5F97;
}

.mine-create-desc {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #7B746B;
}

.mine-create-button {
  width: 100%;
  margin-top: 28rpx;
}

.mine-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 42rpx;
}

.mine-section-title {
  margin: 0;
}

.mine-card-section-head {
  margin-top: 0;
}

.section-action {
  width: 120rpx;
  height: 62rpx;
  margin: 0;
  font-size: 24rpx;
}

.paw-memory-list {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
}

.paw-memory-item {
  overflow: hidden;
}

.paw-memory-media {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #2E2E2A;
}

.paw-memory-body {
  padding: 24rpx;
}

.paw-memory-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.paw-memory-pet {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 700;
  color: #5B5F97;
}

.paw-memory-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.paw-memory-content {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #2E2E2A;
}

.paw-memory-title {
  font-weight: 700;
  color: #5B5F97;
}

.paw-memory-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  justify-items: center;
  box-sizing: border-box;
  min-height: 86rpx;
  padding: 12rpx 20rpx 24rpx;
  border-top: 1rpx solid rgba(232, 220, 203, 0.58);
}

.paw-memory-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  max-width: 154rpx;
  height: 58rpx;
  gap: 8rpx;
  line-height: 1;
  color: #111820;
}

.paw-action-icon {
  position: relative;
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 40rpx;
  height: 40rpx;
  color: #111820;
}

.heart-icon {
  width: auto;
  min-width: 40rpx;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
  color: #111820;
}

.comment-icon {
  width: 40rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% 50% 46% 50%;
  transform: rotate(5deg);
}

.comment-icon::after {
  content: "";
  position: absolute;
  right: 2rpx;
  bottom: -3rpx;
  width: 13rpx;
  height: 13rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(34deg);
  transform-origin: center;
  background: #FFFCF7;
}

.paw-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  font-size: 30rpx;
  line-height: 1;
}

.paw-action-count {
  overflow: hidden;
  max-width: 46rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1;
  color: #111820;
}

.paw-save-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  color: #D6AB4F;
}
