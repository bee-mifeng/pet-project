.admin-entry {
  display: grid;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 26rpx;
  border-color: rgba(214, 171, 79, 0.5);
  background: #FFFCF7;
}

.admin-entry-body {
  min-width: 0;
}

.admin-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.admin-entry-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(46, 46, 42, 0.62);
}

.admin-entry-button {
  width: 100%;
  height: 76rpx;
  margin: 0;
  font-size: 26rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 55%, #F2A45C 100%);
}

.mine-list {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.mine-item {
  display: grid;
  grid-template-columns: 168rpx 1fr;
  gap: 22rpx;
  padding: 20rpx;
}

.mine-photo {
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
}

.mine-body {
  min-width: 0;
  padding: 8rpx 0;
}

.mine-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.mine-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.mine-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.mine-time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(46, 46, 42, 0.62);
}

.meta-dot {
  color: rgba(46, 46, 42, 0.34);
}

.status-chip {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #B7657C;
  background: rgba(231, 160, 179, 0.14);
}

.status-star {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.visibility-public {
  color: #5B5F97;
  background: rgba(91, 95, 151, 0.12);
}

.visibility-pending {
  color: #A67A16;
  background: rgba(214, 171, 79, 0.14);
}

.visibility-private {
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.16);
}

.visibility-rejected {
  color: #9A4A4A;
  background: rgba(154, 74, 74, 0.12);
}

.empty-button {
  margin-top: 24rpx;
}
