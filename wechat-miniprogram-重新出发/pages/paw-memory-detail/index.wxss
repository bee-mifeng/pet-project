@import "../paw-memory/index.wxss";

.paw-memory-detail-page {
  padding-top: 32rpx;
}

.detail-card {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.detail-card .paw-card-head {
  padding-right: 104rpx;
}

.detail-more-button {
  position: absolute;
  right: 28rpx;
  top: 34rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 58rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  gap: 5rpx;
  border: 0;
  border-radius: 999rpx;
  color: #7B746B;
  background: rgba(255, 252, 247, 0.84);
  line-height: 1;
}

.detail-more-button text {
  display: block;
  width: 7rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.detail-more-button:active {
  background: rgba(175, 166, 219, 0.14);
}

.comments-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.comments-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-section-title {
  margin: 0;
}

.comment-list {
  height: auto;
  margin-top: 18rpx;
}

.comment-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(232, 220, 203, 0.72);
}

.comment-item:first-child {
  padding-top: 0;
}

.comment-item:last-child {
  border-bottom: 0;
}

.comment-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.comment-avatar-wrap,
.reply-avatar-wrap {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
}

.comment-avatar,
.comment-avatar-img {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.comment-avatar-img,
.reply-avatar-img {
  display: block;
  background: rgba(175, 166, 219, 0.18);
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-copy {
  margin-top: 6rpx;
  font-size: 29rpx;
  line-height: 1.55;
  color: #111820;
}

.comment-author-line {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.comment-author,
.reply-author {
  display: block;
  overflow: hidden;
  max-width: 360rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
  color: rgba(17, 24, 32, 0.48);
  text-decoration: underline;
  text-underline-offset: 3rpx;
}

.reply-author {
  max-width: 300rpx;
  font-size: 25rpx;
}

.pending-badge {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(183, 101, 124, 0.1);
  font-size: 22rpx;
  font-weight: 700;
  color: #B7657C;
}

.comment-text {
  color: #2E2E2A;
}

.comment-actions-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  width: 100%;
  gap: 16rpx;
  margin-top: 12rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
  color: rgba(17, 24, 32, 0.58);
}

.comment-meta-inline,
.comment-tools-inline {
  display: flex;
  align-items: center;
  min-width: 0;
}

.comment-meta-inline {
  flex: 1 1 auto;
  gap: 14rpx;
}

.comment-tools-inline {
  flex: 0 0 auto;
  justify-content: flex-end;
  gap: 14rpx;
  margin-left: auto;
  text-align: right;
}

.comment-time {
  flex: 0 0 auto;
  font-weight: 500;
  white-space: nowrap;
}

.comment-like-text,
.reply-open {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  height: auto;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.comment-like-text {
  min-width: 54rpx;
  justify-content: flex-end;
}

.comment-like-text::after,
.reply-open::after {
  border: 0;
}

.comment-like-text,
.reply-open {
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
  color: rgba(17, 24, 32, 0.58);
  white-space: nowrap;
}

.comment-like-text.active {
  color: #B7657C;
}

.comment-like-icon {
  font-size: 31rpx;
  font-weight: 400;
  line-height: 1;
}

.comment-like-count {
  margin-left: 6rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
}

.author-liked {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(123, 116, 107, 0.1);
  font-size: 23rpx;
  font-weight: 700;
  color: rgba(17, 24, 32, 0.46);
  white-space: nowrap;
}

.author-reply {
  margin-top: 18rpx;
  padding-left: 74rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #2E2E2A;
}

.author-reply-label {
  display: block;
  margin-right: 12rpx;
  margin-bottom: 6rpx;
  font-weight: 700;
  color: rgba(17, 24, 32, 0.48);
}

.author-reply-content {
  color: rgba(46, 46, 42, 0.74);
}

.reply-thread {
  margin-top: 18rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid rgba(232, 220, 203, 0.78);
}

.thread-reply {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx 0 0 18rpx;
}

.reply-avatar,
.reply-avatar-img {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.18);
}

.reply-main {
  flex: 1;
  min-width: 0;
}

.reply-copy {
  margin-top: 5rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #2E2E2A;
}

.reply-mention {
  color: #5B5F97;
  font-weight: 700;
}

.reply-actions-row {
  margin-top: 10rpx;
}

.reply-form {
  margin-top: 14rpx;
  margin-left: 74rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.72);
}

.reply-input {
  box-sizing: border-box;
  width: 100%;
  height: 128rpx;
  padding: 20rpx;
  border: 1rpx solid #E8DCCB;
  border-radius: 22rpx;
  background: #FBF8F1;
  font-size: 25rpx;
  line-height: 1.55;
  color: #2E2E2A;
}

.reply-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.reply-cancel,
.reply-submit {
  width: 100%;
  height: 68rpx;
  margin: 0;
  font-size: 24rpx;
}

.comment-card-gate {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 220, 203, 0.9);
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.74);
}

.gate-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #2E2E2A;
}

.gate-copy {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(46, 46, 42, 0.62);
}

.gate-button {
  width: 100%;
  height: 76rpx;
  margin-top: 18rpx;
  font-size: 25rpx;
}

.reply-target-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin: 20rpx 0 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(91, 95, 151, 0.1);
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5F97;
}

.reply-target-cancel {
  flex: 0 0 auto;
  width: auto;
  min-width: 84rpx;
  height: 44rpx;
  margin: 0;
  padding: 0 16rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  color: rgba(46, 46, 42, 0.64);
}

.reply-target-cancel::after {
  border: 0;
}

.memory-action-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  background: rgba(46, 46, 42, 0.38);
}

.memory-action-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 41;
  box-sizing: border-box;
  padding: 18rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at 92% 8%, rgba(231, 160, 179, 0.18), transparent 170rpx),
    linear-gradient(180deg, #FFFCF7 0%, #FBF8F1 100%);
  box-shadow: 0 -18rpx 44rpx rgba(46, 46, 42, 0.16);
}

.memory-action-handle {
  width: 74rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: rgba(123, 116, 107, 0.22);
}

.memory-action-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 0 4rpx 22rpx;
}

.memory-action-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border-radius: 999rpx;
  background: rgba(175, 166, 219, 0.16);
  font-size: 30rpx;
  line-height: 1;
}

.memory-action-title {
  font-size: 31rpx;
  font-weight: 800;
  color: #5B5F97;
}

.memory-action-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: rgba(46, 46, 42, 0.58);
}

.memory-action-list {
  overflow: hidden;
  border: 1rpx solid rgba(232, 220, 203, 0.86);
  border-radius: 26rpx;
  background: rgba(255, 252, 247, 0.82);
}

.memory-action-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid rgba(232, 220, 203, 0.72);
}

.memory-action-item:last-child {
  border-bottom: 0;
}

.memory-action-item:active {
  background: rgba(175, 166, 219, 0.08);
}

.memory-action-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.hide-action .memory-action-icon {
  color: #5B5F97;
  background: rgba(91, 95, 151, 0.12);
}

.delete-action .memory-action-icon {
  color: #9A4A4A;
  background: rgba(154, 74, 74, 0.1);
}

.memory-action-copy {
  min-width: 0;
  flex: 1;
}

.memory-action-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2E2E2A;
}

.delete-action .memory-action-name {
  color: #9A4A4A;
}

.memory-action-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: rgba(46, 46, 42, 0.56);
}

.memory-action-cancel {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(232, 220, 203, 0.74);
  font-size: 28rpx;
  font-weight: 800;
  color: rgba(46, 46, 42, 0.68);
}

.memory-action-cancel:active {
  background: rgba(175, 166, 219, 0.1);
}
