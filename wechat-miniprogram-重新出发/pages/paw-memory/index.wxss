.paw-title-row {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  min-height: 58rpx;
  padding-right: 76rpx;
}

.notification-entry {
  position: absolute;
  right: 0;
  top: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  height: 64rpx;
  min-height: 64rpx;
  max-height: 64rpx;
  margin: 0;
  padding: 0;
  overflow: visible;
  color: #5B5F97;
  border-radius: 999rpx;
  background: rgba(255, 252, 247, 0.92);
  box-shadow: 0 10rpx 26rpx rgba(91, 95, 151, 0.1);
  line-height: 1;
  transform: translateY(-50%);
}

.notification-entry:active {
  opacity: 0.76;
}

.notification-entry.has-unread {
  color: #B7657C;
  background: rgba(231, 160, 179, 0.14);
  box-shadow: 0 12rpx 28rpx rgba(183, 101, 124, 0.14);
}

.bell-icon {
  position: relative;
  display: block;
  box-sizing: border-box;
  width: 28rpx;
  height: 30rpx;
  border: 5rpx solid currentColor;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 9rpx 9rpx;
  background: transparent;
}

.bell-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  width: 38rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.bell-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -16rpx;
  width: 9rpx;
  height: 9rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.notification-badge {
  position: absolute;
  right: 0;
  top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-width: 30rpx;
  max-width: 58rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border: 2rpx solid #FDF8F1;
  border-radius: 999rpx;
  color: #FFFCF7;
  background: #E7A0B3;
  box-shadow: 0 6rpx 14rpx rgba(183, 101, 124, 0.22);
  font-size: 17rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.publish-button {
  width: 100%;
  margin: 30rpx 0 24rpx;
}

.filters {
  width: 100%;
  margin-bottom: 26rpx;
}

.filter-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(175, 166, 219, 0.46);
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #5B5F97;
  background: #FFFCF7;
}

.filter.active {
  color: #FFFCF7;
  border-color: #5B5F97;
  background: #5B5F97;
}

.paw-feed {
  display: grid;
  gap: 22rpx;
}

.paw-card {
  overflow: hidden;
  padding: 0;
}

.paw-card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 26rpx 0;
}

.pet-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: rgba(175, 166, 219, 0.16);
}

.pet-card-link {
  cursor: pointer;
}

.pet-card-link:active {
  opacity: 0.72;
}

.pet-info {
  min-width: 0;
  flex: 1;
}

.pet-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.pet-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.pet-type {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #B7657C;
  background: rgba(231, 160, 179, 0.14);
}

.pet-type-dog {
  color: #A05E16;
  background: rgba(242, 164, 92, 0.16);
}

.pet-type-smallPet {
  color: #5F7A43;
  background: rgba(138, 166, 99, 0.16);
}

.pet-type-exoticPet {
  color: #3E7B83;
  background: rgba(94, 167, 176, 0.16);
}

.pet-type-other {
  color: #8A6B16;
  background: rgba(214, 171, 79, 0.16);
}

.time-text {
  color: rgba(46, 46, 42, 0.56);
}

.paw-media,
.paw-video {
  display: block;
  width: 100%;
  height: 430rpx;
  margin-top: 20rpx;
  border-radius: 0;
  background: #2E2E2A;
}

.media-fallback {
  box-sizing: border-box;
  min-height: 240rpx;
  margin-top: 20rpx;
  padding: 52rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(175, 166, 219, 0.14), rgba(214, 171, 79, 0.12)), #FBF8F1;
}

.media-fallback-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #5B5F97;
}

.media-fallback-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7B746B;
}

.paw-content {
  padding: 0 26rpx;
  margin-top: 18rpx;
  font-size: 29rpx;
  line-height: 1.7;
  color: #2E2E2A;
}

.paw-title {
  padding: 0 26rpx;
  margin-top: 22rpx;
  font-size: 31rpx;
  font-weight: 700;
  color: #5B5F97;
}

.paw-title + .paw-content {
  margin-top: 8rpx;
}

.paw-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  justify-items: center;
  column-gap: 0;
  box-sizing: border-box;
  min-height: 86rpx;
  margin-top: 18rpx;
  padding: 12rpx 20rpx 24rpx;
  border-top: 1rpx solid rgba(232, 220, 203, 0.58);
}

.paw-icon-action,
.paw-save-stat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  max-width: 154rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  line-height: 1;
  color: #111820;
  background: transparent;
}

.paw-icon-action::after {
  border: 0;
}

.paw-icon-action {
  gap: 8rpx;
}

.paw-save-stat {
  gap: 8rpx;
}

.ins-icon {
  position: relative;
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 40rpx;
  height: 40rpx;
  color: #111820;
}

.heart-icon {
  width: auto;
  min-width: 40rpx;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
}

.like-action.active .heart-icon {
  color: #B7657C;
}

.comment-icon {
  width: 40rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% 50% 46% 50%;
  transform: rotate(5deg);
}

.comment-icon::after {
  content: "";
  position: absolute;
  right: 2rpx;
  bottom: -3rpx;
  width: 13rpx;
  height: 13rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(34deg);
  transform-origin: center;
  background: #FFFCF7;
}

.paw-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  font-size: 30rpx;
  line-height: 1;
}

.action-count {
  overflow: hidden;
  max-width: 46rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1;
  color: #111820;
}

.save-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  color: #D6AB4F;
}

.comment-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(46, 46, 42, 0.32);
}

.comment-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  box-sizing: border-box;
  max-height: 82vh;
  padding: 18rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #FFFCF7;
}

.comment-handle {
  width: 74rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: rgba(123, 116, 107, 0.24);
}

.comment-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.comment-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #5B5F97;
}

.comment-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.comment-close {
  width: 56rpx;
  height: 56rpx;
  text-align: center;
  font-size: 42rpx;
  line-height: 50rpx;
  color: #7B746B;
}

.comment-list {
  height: 300rpx;
  margin-top: 22rpx;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(232, 220, 203, 0.86);
}

.comment-content {
  font-size: 26rpx;
  line-height: 1.65;
  color: #2E2E2A;
}

.author-reply {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(175, 166, 219, 0.12);
}

.author-reply-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #5B5F97;
}

.author-reply-content {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #2E2E2A;
}

.comment-empty {
  margin-top: 24rpx;
  padding: 34rpx 0;
  text-align: center;
  font-size: 25rpx;
  color: #7B746B;
}

.comment-form {
  margin-top: 20rpx;
}

.comment-input {
  box-sizing: border-box;
  width: 100%;
  height: 140rpx;
  padding: 22rpx;
  border: 1rpx solid #E8DCCB;
  border-radius: 24rpx;
  background: #FBF8F1;
  font-size: 26rpx;
  line-height: 1.55;
  color: #2E2E2A;
}

.comment-submit {
  width: 100%;
  height: 76rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
}
