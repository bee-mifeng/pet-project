.form-card {
  box-sizing: border-box;
  display: grid;
  gap: 34rpx;
  margin-top: 30rpx;
  padding: 28rpx;
  overflow: hidden;
}

.field {
  min-width: 0;
}

.field-help,
.switch-desc,
.count-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7B746B;
}

.count-text {
  text-align: right;
}

.pet-picker-host {
  display: block;
  width: 100%;
}

.pet-picker {
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  width: 100%;
  min-height: 112rpx;
  padding: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E8DCCB;
  border-radius: 26rpx;
  background: #FBF8F1;
}

.pet-avatar {
  flex: 0 0 auto;
  width: 82rpx;
  height: 82rpx;
  border-radius: 999rpx;
  background: rgba(175, 166, 219, 0.16);
}

.pet-picker > view {
  min-width: 0;
  flex: 1;
}

.pet-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 700;
  color: #5B5F97;
}

.pet-meta {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7B746B;
}

.media-actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  box-sizing: border-box;
  width: 100%;
  margin-top: 16rpx;
  overflow: hidden;
}

.media-button {
  flex: 1 1 0;
  box-sizing: border-box;
  width: auto;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0 12rpx;
  font-size: 26rpx;
}

.media-box {
  position: relative;
  margin-top: 18rpx;
}

.media-preview {
  display: block;
  width: 100%;
  height: 390rpx;
  border-radius: 28rpx;
  background: #2E2E2A;
}

.video-tip {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #FFFCF7;
  background: rgba(46, 46, 42, 0.58);
}

.remove-media {
  width: 100%;
  height: 74rpx;
  margin-top: 16rpx;
  font-size: 25rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(175, 166, 219, 0.12);
}

.switch-row > view {
  min-width: 0;
}

.switch-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #5B5F97;
}

.submit-button,
.empty-button {
  width: 100%;
  margin-top: 28rpx;
}
