/* PawsMeadow brand palette
 * pm-purple: #5B5F97; pm-lavender: #AFA6DB; pm-pink: #E7A0B3;
 * pm-orange: #F2A45C; pm-gold: #D6AB4F; pm-cream: #F6F1E8;
 * pm-ink: #2E2E2A; pm-muted: #7B746B; pm-card: #FFFCF7;
 */
page {
  min-height: 100%;
  background: #F6F1E8;
  color: #2E2E2A;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(231, 160, 179, 0.12), transparent 360rpx),
    radial-gradient(circle at 100% 16%, rgba(175, 166, 219, 0.12), transparent 420rpx),
    linear-gradient(180deg, #FDF8F1 0%, #F6F1E8 100%);
}

.page-title {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #5B5F97;
}

.page-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.72;
  color: #7B746B;
}

.card {
  box-sizing: border-box;
  border: 1rpx solid #E8DCCB;
  border-radius: 32rpx;
  background: #FFFCF7;
  box-shadow: 0 18rpx 48rpx rgba(175, 166, 219, 0.14);
}

.primary-button,
.ghost-button,
.quiet-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
}

.primary-button {
  color: #FFFCF7;
  background: linear-gradient(135deg, #5B5F97 0%, #E7A0B3 55%, #F2A45C 100%);
  box-shadow: 0 18rpx 34rpx rgba(91, 95, 151, 0.18);
}

.ghost-button {
  color: #5B5F97;
  background: #FFFCF7;
  border: 1rpx solid #AFA6DB;
}

.quiet-button {
  color: #5B5F97;
  background: #FFFCF7;
  border: 1rpx solid #AFA6DB;
}

.danger-button {
  color: #FFFCF7;
  background: #9A4A4A;
}

.primary-button::after,
.ghost-button::after,
.quiet-button::after,
.danger-button::after {
  border: 0;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #5B5F97;
  background: rgba(175, 166, 219, 0.16);
}

.muted {
  color: #7B746B;
}

.section-title {
  margin: 48rpx 0 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #5B5F97;
}

.empty {
  padding: 48rpx 28rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7B746B;
  background:
    radial-gradient(circle at 50% 20%, rgba(175, 166, 219, 0.18), transparent 180rpx),
    linear-gradient(135deg, rgba(231, 160, 179, 0.1), rgba(242, 164, 92, 0.08)),
    #FFFCF7;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #5B5F97;
}

.form-control {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid #E8DCCB;
  border-radius: 24rpx;
  background: #FBF8F1;
  font-size: 28rpx;
  color: #2E2E2A;
}

.form-control:focus {
  border-color: #AFA6DB;
}

.textarea {
  min-height: 190rpx;
  line-height: 1.65;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
