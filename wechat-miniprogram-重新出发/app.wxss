page {
  min-height: 100%;
  background: #fbf7ee;
  color: #1f2d2a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(218, 172, 67, 0.13), transparent 360rpx),
    radial-gradient(circle at 100% 16%, rgba(122, 136, 118, 0.15), transparent 420rpx),
    #fbf7ee;
}

.page-title {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2f4b38;
}

.page-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.72;
  color: rgba(31, 45, 42, 0.72);
}

.card {
  box-sizing: border-box;
  border: 1rpx solid rgba(47, 75, 56, 0.1);
  border-radius: 32rpx;
  background: rgba(255, 253, 248, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(31, 45, 42, 0.07);
}

.primary-button,
.ghost-button,
.quiet-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
}

.primary-button {
  color: #fffdf8;
  background: #2f4b38;
}

.ghost-button {
  color: #2f4b38;
  background: rgba(47, 75, 56, 0.1);
}

.quiet-button {
  color: #2f4b38;
  background: #fffdf8;
  border: 1rpx solid rgba(47, 75, 56, 0.12);
}

.danger-button {
  color: #8d5d54;
  background: rgba(141, 93, 84, 0.1);
}

.primary-button::after,
.ghost-button::after,
.quiet-button::after,
.danger-button::after {
  border: 0;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2f4b38;
  background: rgba(122, 136, 118, 0.16);
}

.muted {
  color: rgba(31, 45, 42, 0.62);
}

.section-title {
  margin: 48rpx 0 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f4b38;
}

.empty {
  padding: 48rpx 28rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(31, 45, 42, 0.62);
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #2f4b38;
}

.form-control {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid rgba(47, 75, 56, 0.14);
  border-radius: 24rpx;
  background: #fffaf1;
  font-size: 28rpx;
  color: #1f2d2a;
}

.textarea {
  min-height: 190rpx;
  line-height: 1.65;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
