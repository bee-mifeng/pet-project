.pet-card {
  overflow: hidden;
}

.pet-photo {
  display: block;
  width: 100%;
  height: 360rpx;
  background: #dde6de;
}

.pet-body {
  padding: 28rpx;
}

.pet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.pet-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #3f513f;
}

.pet-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(31, 45, 61, 0.58);
}

.status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #3f513f;
  background: rgba(125, 143, 122, 0.16);
}

.pet-story {
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.65;
  color: rgba(31, 45, 61, 0.76);
}

.pet-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.pet-stat {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(31, 45, 61, 0.7);
  background: rgba(221, 230, 222, 0.58);
}

.detail-button {
  margin-top: 26rpx;
}
