.hero {
  padding: 16rpx 0 18rpx;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 34rpx;
}

.trust {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #3f513f;
  background: rgba(221, 230, 222, 0.62);
}

.feature-list,
.faq-list {
  display: grid;
  gap: 18rpx;
}

.feature-card,
.faq,
.note-card,
.steps {
  padding: 28rpx;
}

.feature-title,
.faq-q {
  font-size: 30rpx;
  font-weight: 700;
  color: #3f513f;
}

.feature-desc,
.faq-a,
.note-card {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.68;
  color: rgba(31, 45, 61, 0.7);
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(63, 81, 63, 0.08);
}

.step:last-child {
  border-bottom: none;
}

.step-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 42rpx;
  font-size: 22rpx;
  color: #fbf8f1;
  background: #3f513f;
}

.step-text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.55;
}

.policy-links {
  margin-top: 18rpx;
  color: #9e6f66;
}
