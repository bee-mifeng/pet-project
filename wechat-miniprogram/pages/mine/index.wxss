.create-button {
  margin-top: 32rpx;
}

.mine-list {
  display: grid;
  gap: 24rpx;
}

.mine-item {
  display: grid;
  gap: 14rpx;
}

.delete-button {
  width: 100%;
}

.loading {
  padding: 48rpx 0;
  text-align: center;
  color: rgba(31, 45, 61, 0.58);
}

.links {
  display: grid;
  gap: 2rpx;
  overflow: hidden;
}

.policy-link {
  padding: 28rpx;
  font-size: 27rpx;
  color: #3f513f;
  background: rgba(255, 252, 246, 0.92);
  border-bottom: 1rpx solid rgba(63, 81, 63, 0.08);
}

.policy-link-last {
  border-bottom: none;
}

.debug-openid {
  margin-top: 26rpx;
  padding: 24rpx;
}

.debug-title {
  font-size: 24rpx;
  color: #9e6f66;
}

.debug-value {
  margin-top: 10rpx;
  word-break: break-all;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(31, 45, 61, 0.66);
}
