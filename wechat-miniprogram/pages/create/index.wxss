.form-card {
  margin-top: 32rpx;
  padding: 30rpx;
}

.field {
  margin-bottom: 28rpx;
}

.picker-value {
  color: rgba(31, 45, 61, 0.78);
}

.textarea.short {
  min-height: 150rpx;
}

.upload-box {
  overflow: hidden;
  min-height: 340rpx;
  margin: 18rpx 0 30rpx;
  border: 2rpx dashed rgba(63, 81, 63, 0.22);
  border-radius: 28rpx;
  background: rgba(221, 230, 222, 0.26);
}

.upload-preview {
  display: block;
  width: 100%;
  height: 360rpx;
}

.upload-placeholder {
  padding: 86rpx 34rpx;
  text-align: center;
}

.upload-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3f513f;
}

.upload-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: rgba(31, 45, 61, 0.62);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(63, 81, 63, 0.08);
}

.switch-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3f513f;
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(31, 45, 61, 0.58);
}

.submit-button {
  margin-top: 26rpx;
}
