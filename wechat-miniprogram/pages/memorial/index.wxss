.loading {
  padding: 80rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: rgba(31, 45, 61, 0.58);
}

.cover {
  width: 100%;
  height: 520rpx;
  overflow: hidden;
  background: #dde6de;
}

.profile {
  margin-top: 24rpx;
  padding: 30rpx;
}

.profile-top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.pet-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #3f513f;
}

.pet-meta {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: rgba(31, 45, 61, 0.62);
}

.status-note {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
  line-height: 1.58;
  color: #3f513f;
  background: rgba(221, 230, 222, 0.58);
}

.status-button {
  margin-top: 22rpx;
}

.story,
.message-card,
.closed {
  padding: 30rpx;
  font-size: 28rpx;
  line-height: 1.78;
  color: rgba(31, 45, 61, 0.76);
}

.actions {
  display: grid;
  gap: 18rpx;
  margin-top: 32rpx;
}

.comment-form {
  display: grid;
  gap: 18rpx;
  padding: 28rpx;
}

.comment-textarea {
  min-height: 160rpx;
}

.messages {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.message-item {
  padding: 26rpx;
}

.message-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #3f513f;
}

.message-content {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.66;
  color: rgba(31, 45, 61, 0.72);
}
