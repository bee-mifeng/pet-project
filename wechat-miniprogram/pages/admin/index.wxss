.notice {
  margin-top: 28rpx;
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #9e6f66;
  background: rgba(158, 111, 102, 0.08);
}

.no-access,
.admin-openid {
  margin-top: 26rpx;
  padding: 26rpx;
}

.no-access-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #9e6f66;
}

.no-access-desc,
.admin-openid {
  word-break: break-all;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(31, 45, 61, 0.66);
}

.no-access-desc {
  margin-top: 12rpx;
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin: 30rpx 0;
}

.tab {
  height: 70rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 70rpx;
  font-size: 26rpx;
  color: #3f513f;
  background: rgba(63, 81, 63, 0.08);
}

.tab.active {
  color: #fbf8f1;
  background: #3f513f;
}

.loading {
  padding: 48rpx 0;
  text-align: center;
  color: rgba(31, 45, 61, 0.58);
}

.review-list,
.message-list {
  display: grid;
  gap: 26rpx;
}

.review-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.message-card {
  padding: 28rpx;
}

.message-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #3f513f;
}

.message-content {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.68;
  color: rgba(31, 45, 61, 0.72);
}
