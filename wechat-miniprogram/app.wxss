.page {
  min-height: 100vh;
  padding: 32rpx;
  background:
    radial-gradient(circle at 6% 0%, rgba(212, 175, 55, 0.14), transparent 420rpx),
    radial-gradient(circle at 100% 24%, rgba(125, 143, 122, 0.16), transparent 440rpx),
    #fbf8f1;
}

.page-title {
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #3f513f;
  letter-spacing: 0;
}

.page-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.72;
  color: rgba(31, 45, 61, 0.72);
}

.card {
  border: 1rpx solid rgba(63, 81, 63, 0.1);
  border-radius: 28rpx;
  background: rgba(255, 252, 246, 0.92);
  box-shadow: 0 14rpx 40rpx rgba(31, 45, 61, 0.06);
}

.primary-button,
.ghost-button,
.quiet-button,
.danger-button {
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  border: none;
}

.primary-button {
  color: #fbf8f1;
  background: #3f513f;
}

.ghost-button {
  color: #3f513f;
  background: rgba(63, 81, 63, 0.08);
}

.quiet-button {
  color: #3f513f;
  background: #ffffff;
  border: 1rpx solid rgba(63, 81, 63, 0.12);
}

.danger-button {
  color: #9e6f66;
  background: rgba(158, 111, 102, 0.1);
}

.primary-button::after,
.ghost-button::after,
.quiet-button::after,
.danger-button::after {
  border: none;
}

.badge {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #3f513f;
  background: rgba(125, 143, 122, 0.16);
}

.muted {
  color: rgba(31, 45, 61, 0.62);
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #3f513f;
}

.form-control {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid rgba(63, 81, 63, 0.14);
  border-radius: 24rpx;
  background: #fffaf2;
  font-size: 28rpx;
  color: #1f2d3d;
}

.textarea {
  min-height: 190rpx;
  line-height: 1.65;
}
